# Environment Variables
# Kopiere diese Datei als .env und fülle die Werte aus
# Secrets NIEMALS committen - nur auf dem Server in /var/www/bereifung24/.env eintragen

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bereifung24"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Encryption Key for Employee Portal (AES-256)
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Google OAuth for NextAuth Login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google OAuth for Calendar Integration
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Redis Cache
REDIS_URL="redis://localhost:6379"

# ================================================
# Die folgenden Keys werden über das Admin-Panel
# verwaltet (/admin/api-settings) und in der
# Datenbank gespeichert. NICHT in .env eintragen!
# ================================================
# GOOGLE_MAPS_API_KEY    → Admin Panel
# PAYPAL_CLIENT_ID       → Admin Panel
# PAYPAL_CLIENT_SECRET   → Admin Panel
# STRIPE_SECRET_KEY      → Admin Panel
# STRIPE_PUBLISHABLE_KEY → Admin Panel
# WEATHERAPI_KEY         → Admin Panel
# GEMINI_API_KEY         → Admin Panel
# EMAIL_HOST/PASSWORD    → Admin Panel (E-Mail-Einstellungen)